stages:
  - test
  - upload
  - gate

variables:
  DOJO_URL: "{{ dojo_url }}"
  DOJO_KEY: "{{ dojo_key }}"
  PRODUCT_NAME: "{{ product_name }}"
  ENGAGEMENT_NAME: "{{ engagement_name }}"
  TELEGRAM_TOKEN: "{{ telegram_token }}"
  TELEGRAM_CHAT_ID: "{{ telegram_chat_id }}"

# =========================
# GITLAB NATIVE SAST (NO CUSTOM IMAGE)
# =========================
include:
  - template: Security/SAST.gitlab-ci.yml

# --------------------
# UPLOAD TO DEFECTDOJO
# --------------------
upload-test:
  stage: upload
  image: curlimages/curl:latest
  needs:
    - job: semgrep-sast
      artifacts: true

  script:
    - echo "Listing files..."
    - find . -name "*sast*"

    - FILE="gl-sast-report.json"

    - |
      if [ ! -f "$FILE" ]; then
        echo "❌ SAST report not found!"
        ls -la
        exit 1
      fi

    - |
      curl -X POST "{{ dojo_url }}/api/v2/reimport-scan/" \
        -H "Authorization: Token {{ dojo_key }}" \
        -F "active=true" \
        -F "verified=true" \
        -F "scan_type=GitLab SAST Report" \
        -F "minimum_severity=High" \
        -F "product_name={{ product_name }}" \
        -F "engagement_name={{ engagement_name }}" \
        -F "test_title=Semgrep Scan - Test 1" \
        -F "auto_create_context=true" \
        -F "file=@$FILE"

# --- SECURITY GATE ---
security-gate:
  stage: gate
  image: curlimages/curl:latest
  needs: ["upload-test"]

  script:
    - |
      echo "🔍 Verifying security status for Test 1..."

      # 1. Query DefectDojo
      RESPONSE=$(curl -s -H "Authorization: Token $DOJO_KEY" \
        "$DOJO_URL/api/v2/findings/?active=true&verified=true&test__title=Semgrep%20Scan%20-%20Test%201")

      # 2. Extract count safely
      COUNT=$(echo "$RESPONSE" | grep -o '"count":[0-9]*' | cut -d: -f2)
      COUNT=${COUNT:-0}

      echo "Findings Count: $COUNT"

      if [ "$COUNT" -gt 0 ]; then

        HASHES=$(echo "$RESPONSE" | grep -o '"hash_code":"[^"]*"' | cut -d'"' -f4 | head -n 5)

        MSG="❌ Security Gate Warning (Test 1)\nFound $COUNT active vulnerabilities.\n\nTop Hashes:\n$HASHES\n\nPipeline continuing in Soft Fail mode."

      else

        MSG="✅ Security Gate Passed (Test 1)\nNo active findings (All fixed or False Positive)."

      fi

      # Encode for Telegram
      ENCODED_MSG=$(echo "$MSG" | sed ':a;N;$!ba;s/\n/%0A/g')

      # Send Telegram message
      curl -s -X POST "https://api.telegram.org/bot$TELEGRAM_TOKEN/sendMessage" \
        -d "chat_id=$TELEGRAM_CHAT_ID" \
        -d "text=$ENCODED_MSG"
        
